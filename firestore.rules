rules_version = '2';

/* Règles d'accès à Firestore — à coller dans la console Firebase :
   Firestore Database -> onglet Règles -> Publier.

   Sans elles, la base refuse tout (mode production) et l'app affichera
   « Accès refusé par les règles de la base ». */

service cloud.firestore {
  match /databases/{database}/documents {

    function connecte() {
      return request.auth != null;
    }

    /* Réglages personnels : thème, couleur, pseudo, code ami, jetons de
       notification. Chacun chez soi. */
    match /users/{userId} {
      allow read, write: if connecte() && request.auth.uid == userId;
    }

    /* Annuaire des codes ami : code -> compte. Consultable un par un si l'on
       connaît le code exact (`get`), jamais listable — personne ne peut
       parcourir l'annuaire. Un code, une fois pris, est définitif. */
    match /codes/{code} {
      allow get: if connecte();
      allow create: if connecte() && request.resource.data.uid == request.auth.uid;
    }

    /* Invitations en attente. Adressées soit à une adresse e-mail (la personne
       n'a peut-être pas de compte), soit à un identifiant de compte (invitée par
       son code ami). Les deux champs existent toujours, l'un vide : l'accès
       direct — et non `get` — est nécessaire pour que Firestore autorise les
       requêtes filtrées dessus. */
    match /invites/{inviteId} {

      allow create: if connecte()
        && request.resource.data.invitePar == request.auth.uid
        && request.auth.uid in get(/databases/$(database)/documents/lists/$(request.resource.data.listId)).data.members;

      allow read, delete: if connecte()
        && (resource.data.cibleEmail == request.auth.token.email
            || resource.data.cibleUid == request.auth.uid
            || resource.data.invitePar == request.auth.uid);
    }

    match /lists/{listId} {

      function membresApres() { return request.resource.data.get('members', []); }

      // Accès direct pour la lecture : autoriser la requête `array-contains`
      // suppose que Firestore reconnaisse le champ, ce qu'un `get` lui masque.
      function membre() {
        return connecte() && request.auth.uid in resource.data.members;
      }

      function proprietaire() {
        return connecte() && request.auth.uid == resource.data.get('owner', '');
      }

      // Le contenu change, l'appartenance non : cocher, renommer, réordonner.
      // `get` avec valeur par défaut, car les listes d'avant le partage n'ont
      // pas de `memberEmails` et lire un champ absent ferait échouer la règle.
      function contenuSeul() {
        return request.resource.data.get('owner', '') == resource.data.get('owner', '')
          && membresApres() == resource.data.members
          && request.resource.data.get('memberEmails', []) == resource.data.get('memberEmails', []);
      }

      // Un invité s'ajoute lui-même, et rien d'autre. On vérifie qu'une
      // invitation existe à son nom — par adresse ou par identifiant.
      function accepteInvitation() {
        return connecte()
          && (exists(/databases/$(database)/documents/invites/$(listId + '__' + request.auth.token.email))
              || exists(/databases/$(database)/documents/invites/$(listId + '__u_' + request.auth.uid)))
          && request.resource.data.get('owner', '') == resource.data.get('owner', '')
          && membresApres() == resource.data.members.concat([request.auth.uid]);
      }

      // Quitter une liste : on se retire, sans toucher aux autres.
      function seRetire() {
        return membre()
          && request.resource.data.get('owner', '') == resource.data.get('owner', '')
          && !(request.auth.uid in membresApres())
          && resource.data.members.hasAll(membresApres());
      }

      allow create: if connecte()
        && request.resource.data.owner == request.auth.uid
        && request.resource.data.members.hasOnly([request.auth.uid]);

      allow read: if membre();

      // Supprimer pour tout le monde reste au propriétaire ; les autres quittent.
      allow delete: if proprietaire();

      allow update: if (membre() && contenuSeul())
        || (proprietaire() && request.resource.data.get('owner', '') == resource.data.get('owner', ''))
        || accepteInvitation()
        || seRetire();
    }
  }
}
