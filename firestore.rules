rules_version = '2';

/* Règles d'accès à Firestore — à coller dans la console Firebase :
   Firestore Database -> onglet Règles -> Publier.

   Sans elles, la base refuse tout (mode production) et l'app affichera
   « Accès refusé par les règles de la base ». */

service cloud.firestore {
  match /databases/{database}/documents {

    function connecte() {
      return request.auth != null;
    }

    /* Réglages personnels : thème et couleur d'accent. Chacun chez soi. */
    match /users/{userId} {
      allow read, write: if connecte() && request.auth.uid == userId;
    }

    /* Invitations en attente. Elles sont déposées au nom d'une adresse e-mail,
       parce que rien ne permet de traduire une adresse en identifiant de compte
       avant que la personne se connecte. */
    match /invites/{inviteId} {

      // Seul un membre de la liste concernée peut inviter quelqu'un.
      allow create: if connecte()
        && request.resource.data.invitePar == request.auth.uid
        && request.auth.uid in get(/databases/$(database)/documents/lists/$(request.resource.data.listId)).data.members;

      // On voit une invitation si elle nous est adressée, ou si on l'a émise.
      allow read, delete: if connecte()
        && (resource.data.email == request.auth.token.email
            || resource.data.invitePar == request.auth.uid);
    }

    match /lists/{listId} {

      function membresApres() { return request.resource.data.get('members', []); }

      /* Accès direct, et non `get` : pour autoriser une *requête*, Firestore
         doit prouver d'avance qu'elle est permise, en reconnaissant la forme
         « champ filtré ↔ champ de la règle ». Un `get` la lui masque, et toute
         lecture de liste est alors refusée. Ailleurs — modifications, portant
         sur un seul document — la question ne se pose pas et `get` protège des
         champs absents. */
      function membre() {
        return connecte() && request.auth.uid in resource.data.members;
      }

      function proprietaire() {
        return connecte() && request.auth.uid == resource.data.get('owner', '');
      }

      // Le contenu change, l'appartenance non : c'est le cas de loin le plus
      // fréquent — cocher un article, renommer, réordonner.
      function contenuSeul() {
        return request.resource.data.get('owner', '') == resource.data.get('owner', '')
          && membresApres() == resource.data.members
          && request.resource.data.get('memberEmails', []) == resource.data.get('memberEmails', []);
      }

      // Quelqu'un d'invité s'ajoute lui-même, et rien d'autre. L'invitation
      // porte un identifiant déterministe, ce qui permet de la vérifier ici.
      function accepteInvitation() {
        return connecte()
          && exists(/databases/$(database)/documents/invites/$(listId + '__' + request.auth.token.email))
          && request.resource.data.get('owner', '') == resource.data.get('owner', '')
          && membresApres() == resource.data.members.concat([request.auth.uid]);
      }

      // Quitter une liste : on se retire, sans toucher aux autres.
      function seRetire() {
        return membre()
          && request.resource.data.get('owner', '') == resource.data.get('owner', '')
          && !(request.auth.uid in membresApres())
          && resource.data.members.hasAll(membresApres());
      }

      allow create: if connecte()
        && request.resource.data.owner == request.auth.uid
        && request.resource.data.members.hasOnly([request.auth.uid]);

      allow read: if membre();

      // Supprimer la liste pour tout le monde reste au propriétaire. Les autres
      // la quittent — sans quoi un invité pourrait effacer le travail commun.
      allow delete: if proprietaire();

      allow update: if (membre() && contenuSeul())
        || (proprietaire() && request.resource.data.owner == resource.data.owner)
        || accepteInvitation()
        || seRetire();
    }
  }
}
